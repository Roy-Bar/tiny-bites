rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /babies/{babyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /feedings/{feedingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /sleeps/{sleepId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Product update / new-feature announcements. Any signed-in user can read;
    // they're authored manually in the Firestore console (which bypasses rules),
    // so client writes stay denied.
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
    }
  }
}
